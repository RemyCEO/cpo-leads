{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/bodyguard-jobs", "destination": "/bodyguard-jobs.html" },
    { "source": "/close-protection-jobs", "destination": "/close-protection-jobs.html" },
    { "source": "/executive-protection-jobs", "destination": "/executive-protection-jobs.html" },
    { "source": "/maritime-security-jobs", "destination": "/maritime-security-jobs.html" },
    { "source": "/security-jobs-london", "destination": "/security-jobs-london.html" },
    { "source": "/security-jobs-dubai", "destination": "/security-jobs-dubai.html" },
    { "source": "/jobs", "destination": "/api/jobs-page" }
  ]
}
